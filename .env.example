# Copy this file to .env and fill in the values for your machine.
# .env is gitignored; this template is safe to commit (no real secrets).

# Microsoft Foundry Local — OpenAI-compatible endpoint.
# Start the desired model in Microsoft Foundry Local, then obtain the local
# endpoint using the appropriate command for your installed Foundry version.
# Replace the port (5273 below) with the one your Foundry service reports.
# The base URL must include the /v1 suffix used by the OpenAI protocol.
FOUNDRY_BASE_URL=http://127.0.0.1:5273/v1

# The concrete model id served by Foundry Local; obtain it using the appropriate
# command for your installed Foundry version. Foundry may expose different
# identifiers depending on the loaded model.
# This is what the Day-1 Turkish-fluency gate validates; if Phi-4 Mini
# underperforms, switch to the fallback model here — no code change needed.
FOUNDRY_MODEL=<your-loaded-model-id>

# Foundry Local does not authenticate requests, but the OpenAI client requires
# a non-empty key. Any placeholder value works.
FOUNDRY_API_KEY=not-needed
